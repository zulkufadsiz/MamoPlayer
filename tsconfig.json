{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"],
      "@mamoplayer/core": ["./packages/core/src/index.ts"],
      "@mamoplayer/pro": ["./packages/pro/src/index.tsx"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
