    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.10",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.1.4",
    "react-native": "^0.81.0",
