{
  "name": "@mamoplayer/pro",
  "version": "1.0.0",
  "main": "dist/index.js",
  "react-native": "src/index.tsx",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.tsx",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-video": ">=6"
  },
  "dependencies": {
    "@mamoplayer/core": "1.0.0",
    "@react-native-vector-icons/material-icons": "12.4.1"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean",
    "test": "echo \"No tests for @mamoplayer/pro\""
  }
}
