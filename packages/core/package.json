{
  "name": "@mamoplayer/core",
  "version": "1.0.0",
  "main": "dist/index.js",
  "react-native": "src/index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-video": ">=6"
  },
  "dependencies": {
    "@react-native-vector-icons/material-icons": "^12.4.1",
    "@types/react-native-vector-icons": "^6.4.18"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@react-native/babel-preset": "^0.81.6",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.10",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "19.1.4",
    "react-native": "^0.81.0",
    "react-native-video": "^6.17.0",
    "react-test-renderer": "19.1.4",
    "tsup": "^8",
    "typescript": "^5"
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts --format esm,cjs --dts",
    "test": "jest --config ./jest.config.js --runInBand"
  }
}
